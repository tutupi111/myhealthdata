# App subdomain (optional, defaults to https://app.myhealthdata.foundation)
# NEXT_PUBLIC_APP_URL=https://app.myhealthdata.foundation

# App Data Hub — contact event tracking (server-side only, do not expose API key to client)
# Vercel: Project Settings -> Environment Variables -> add to Production -> Redeploy
DATA_HUB_BASE_URL=https://tuutpi.online
DATA_HUB_APP_ID=app_xxx
DATA_HUB_API_KEY=dh_xxx

# Optional aliases (same values; only needed if you copied names from the integration guide)
# VITE_DATA_HUB_BASE_URL=https://tuutpi.online
# VITE_DATA_HUB_APP_ID=app_xxx
# VITE_DATA_HUB_API_KEY=dh_xxx
